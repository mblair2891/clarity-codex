generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  platform_admin
  org_admin
  clinical_staff
  clinician
  case_manager
  billing
  support
  consumer
}

enum PlatformRole {
  platform_admin
  support
}

enum OrganizationRole {
  org_admin
  clinical_staff
  clinician
  case_manager
  billing
  consumer
}

enum MembershipStatus {
  active
  invited
  suspended
  revoked
}

enum ConditionStatus {
  active
  inactive
  resolved
}

enum AppointmentStatus {
  scheduled
  completed
  canceled
  no_show
}

enum ClaimStatus {
  draft
  submitted
  accepted
  denied
  paid
}

enum BillingWorkItemStatus {
  draft
  ready_for_review
  submitted
  needs_correction
  paid
  denied
  follow_up_needed
}

enum SubscriptionStatus {
  draft
  trialing
  active
  past_due
  suspended
  canceled
}

enum OrganizationInvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

enum OrganizationInvoiceLineItemType {
  base_plan
  feature_add_on
  usage_active_client
  usage_clinician
  adjustment
  credit
}

enum AiActionType {
  recovery_coach
  journaling_assist
  weekly_insight
  clinical_summary
  denial_analysis
}

model Tenant {
  id                           String                        @id @default(cuid())
  slug                         String                        @unique
  name                         String
  createdAt                    DateTime                      @default(now())
  organizations                Organization[]
  subscriptionPlans            SubscriptionPlan[]
  platformFeatures             PlatformFeature[]
  organizationSubscriptions    OrganizationSubscription[]
  organizationFeatureOverrides OrganizationFeatureOverride[]
  organizationUsageSnapshots   OrganizationUsageSnapshot[]
  organizationInvoices         OrganizationInvoice[]
  users                        User[]
  consumers                    Consumer[]
  clinicalNotes                ClinicalNote[]
  checkInReviews               CheckInReview[]
  billingWorkItems             BillingWorkItem[]
  billingNotes                 BillingNote[]
  payers                       Payer[]
  promptRegistry               PromptRegistry[]
  aiRuns                       AiRun[]
  auditLogs                    AuditLog[]
}

model Organization {
  id                   String                        @id @default(cuid())
  tenantId             String
  tenant               Tenant                        @relation(fields: [tenantId], references: [id])
  name                 String
  slug                 String?
  npi                  String?
  taxId                String?
  memberships          Membership[]
  locations            Location[]
  consumers            Consumer[]
  clinicalNotes        ClinicalNote[]
  checkInReviews       CheckInReview[]
  billingWorkItems     BillingWorkItem[]
  billingNotes         BillingNote[]
  appointments         Appointment[]
  groups               GroupSession[]
  encounters           Encounter[]
  subscription         OrganizationSubscription?
  featureOverrides     OrganizationFeatureOverride[]
  usageSnapshots       OrganizationUsageSnapshot[]
  organizationInvoices OrganizationInvoice[]
  createdAt            DateTime                      @default(now())

  @@unique([tenantId, slug])
}

model SubscriptionPlan {
  id                        String                     @id @default(cuid())
  tenantId                  String
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id])
  key                       String
  name                      String
  description               String?
  isActive                  Boolean                    @default(true)
  sortOrder                 Int                        @default(0)
  basePriceCents            Int                        @default(0)
  activeClientPriceCents    Int                        @default(0)
  clinicianPriceCents       Int                        @default(0)
  currency                  String                     @default("usd")
  billingInterval           String                     @default("month")
  planFeatures              PlanFeature[]
  organizationSubscriptions OrganizationSubscription[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, isActive, sortOrder])
}

model PlatformFeature {
  id                    String                        @id @default(cuid())
  tenantId              String
  tenant                Tenant                        @relation(fields: [tenantId], references: [id])
  key                   String
  name                  String
  description           String?
  category              String?
  isActive              Boolean                       @default(true)
  sortOrder             Int                           @default(0)
  planFeatures          PlanFeature[]
  organizationOverrides OrganizationFeatureOverride[]
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, isActive, sortOrder])
}

model PlanFeature {
  id        String           @id @default(cuid())
  planId    String
  featureId String
  included  Boolean          @default(true)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  feature   PlatformFeature  @relation(fields: [featureId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([planId, featureId])
  @@index([featureId])
}

model OrganizationSubscription {
  id                     String                      @id @default(cuid())
  tenantId               String
  tenant                 Tenant                      @relation(fields: [tenantId], references: [id])
  organizationId         String                      @unique
  organization           Organization                @relation(fields: [organizationId], references: [id])
  planId                 String?
  plan                   SubscriptionPlan?           @relation(fields: [planId], references: [id])
  status                 SubscriptionStatus          @default(draft)
  billingStatus          String                      @default("not_configured")
  basePriceCents         Int                         @default(0)
  activeClientPriceCents Int                         @default(0)
  clinicianPriceCents    Int                         @default(0)
  currency               String                      @default("usd")
  billingInterval        String                      @default("month")
  startsAt               DateTime                    @default(now())
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  billingProvider        String?
  billingCustomerId      String?
  notes                  String?
  usageSnapshots         OrganizationUsageSnapshot[]
  invoices               OrganizationInvoice[]
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([tenantId, status])
  @@index([planId])
}

model OrganizationFeatureOverride {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id])
  featureId       String
  feature         PlatformFeature @relation(fields: [featureId], references: [id])
  enabled         Boolean
  reason          String?
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, featureId])
  @@index([tenantId, organizationId])
}

model OrganizationUsageSnapshot {
  id               String                    @id @default(cuid())
  tenantId         String
  tenant           Tenant                    @relation(fields: [tenantId], references: [id])
  organizationId   String
  organization     Organization              @relation(fields: [organizationId], references: [id])
  subscriptionId   String?
  subscription     OrganizationSubscription? @relation(fields: [subscriptionId], references: [id])
  snapshotDate     DateTime
  periodStart      DateTime
  periodEnd        DateTime
  activeClients    Int                       @default(0)
  activeClinicians Int                       @default(0)
  metadata         Json?
  createdAt        DateTime                  @default(now())

  @@unique([organizationId, periodStart, periodEnd])
  @@index([tenantId, snapshotDate])
}

model OrganizationInvoice {
  id                String                        @id @default(cuid())
  tenantId          String
  tenant            Tenant                        @relation(fields: [tenantId], references: [id])
  organizationId    String
  organization      Organization                  @relation(fields: [organizationId], references: [id])
  subscriptionId    String?
  subscription      OrganizationSubscription?     @relation(fields: [subscriptionId], references: [id])
  status            OrganizationInvoiceStatus     @default(draft)
  invoiceNumber     String?
  currency          String                        @default("usd")
  subtotalCents     Int                           @default(0)
  totalCents        Int                           @default(0)
  invoiceDate       DateTime                      @default(now())
  dueDate           DateTime?
  paidAt            DateTime?
  billingProvider   String?
  billingCustomerId String?
  externalInvoiceId String?
  notes             String?
  lineItems         OrganizationInvoiceLineItem[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@index([tenantId, status, invoiceDate])
}

model OrganizationInvoiceLineItem {
  id              String                          @id @default(cuid())
  invoiceId       String
  invoice         OrganizationInvoice             @relation(fields: [invoiceId], references: [id])
  type            OrganizationInvoiceLineItemType
  featureKey      String?
  description     String
  quantity        Int                             @default(1)
  unitAmountCents Int                             @default(0)
  amountCents     Int                             @default(0)
  metadata        Json?
  createdAt       DateTime                        @default(now())

  @@index([invoiceId])
}

model User {
  id                      String                    @id @default(cuid())
  tenantId                String
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id])
  consumerId              String?                   @unique
  consumer                Consumer?                 @relation(fields: [consumerId], references: [id])
  email                   String
  normalizedEmail         String?
  fullName                String
  role                    Role
  passwordHash            String?
  isActive                Boolean                   @default(true)
  mustChangePassword      Boolean                   @default(false)
  memberships             Membership[]
  platformRoles           UserPlatformRole[]
  sessions                UserSession[]
  authoredClinicalNotes   ClinicalNote[]
  completedCheckInReviews CheckInReview[]
  createdBillingWorkItems BillingWorkItem[]         @relation("BillingWorkItemCreatedBy")
  updatedBillingWorkItems BillingWorkItem[]         @relation("BillingWorkItemUpdatedBy")
  authoredBillingNotes    BillingNote[]             @relation("BillingNoteAuthor")
  billingActivities       BillingWorkItemActivity[] @relation("BillingWorkItemActivityActor")
  auditLogs               AuditLog[]
  aiRuns                  AiRun[]
  createdAt               DateTime                  @default(now())

  @@unique([tenantId, email])
  @@index([normalizedEmail])
}

model Membership {
  id                  String               @id @default(cuid())
  userId              String
  organizationId      String
  role                Role
  organizationRole    OrganizationRole?
  status              MembershipStatus     @default(active)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id])
  organization        Organization         @relation(fields: [organizationId], references: [id])
  locationAssignments MembershipLocation[]

  @@unique([userId, organizationId])
}

model UserPlatformRole {
  id        String       @id @default(cuid())
  userId    String
  role      PlatformRole
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([userId, role])
  @@index([userId])
}

model UserSession {
  id                     String    @id @default(cuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id])
  activeOrganizationId   String?
  activeMembershipId     String?
  activeLocationId       String?
  supportAccessSessionId String?
  supportMode            Boolean   @default(false)
  expiresAt              DateTime
  revokedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId])
  @@index([activeOrganizationId])
  @@index([activeMembershipId])
  @@index([expiresAt])
}

model Location {
  id                  String               @id @default(cuid())
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id])
  name                String
  timezone            String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  membershipLocations MembershipLocation[]

  @@index([organizationId])
}

model MembershipLocation {
  id           String     @id @default(cuid())
  membershipId String
  locationId   String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id])
  location     Location   @relation(fields: [locationId], references: [id])

  @@unique([membershipId, locationId])
  @@index([membershipId])
  @@index([locationId])
}

model SupportAccessSession {
  id             String    @id @default(cuid())
  supportUserId  String
  organizationId String
  membershipId   String?
  locationId     String?
  reason         String?
  ticketRef      String?
  startedAt      DateTime  @default(now())
  expiresAt      DateTime
  endedAt        DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([supportUserId])
  @@index([organizationId])
  @@index([expiresAt])
}

model Consumer {
  id                  String               @id @default(cuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  organizationId      String
  organization        Organization         @relation(fields: [organizationId], references: [id])
  userAccount         User?
  firstName           String
  lastName            String
  preferredName       String?
  recoveryFocus       String?
  checkInPreference   String?
  dob                 DateTime?
  traumaMode          Boolean              @default(false)
  cognitiveAssistMode Boolean              @default(false)
  checkIns            DailyCheckIn[]
  journals            JournalEntry[]
  goals               Goal[]
  routines            Routine[]
  recoveryPlan        RecoveryPlan?
  conditions          ConsumerCondition[]
  treatmentPlans      TreatmentPlan[]
  medications         MedicationRecord[]
  appointments        Appointment[]
  clinicalNotes       ClinicalNote[]
  checkInReviews      CheckInReview[]
  billingWorkItems    BillingWorkItem[]
  billingNotes        BillingNote[]
  encounters          Encounter[]
  coverages           Coverage[]
  invoices            Invoice[]
  ledgerEntries       PatientLedgerEntry[]
  createdAt           DateTime             @default(now())
}

model DailyCheckIn {
  id                 String         @id @default(cuid())
  organizationId     String
  consumerId         String
  consumer           Consumer       @relation(fields: [consumerId], references: [id])
  review             CheckInReview?
  checkInDate        DateTime
  mood               Int
  cravings           Int
  stressLevel        Int?
  sleepHours         Float?
  sleepQuality       Int?
  motivationLevel    Int?
  treatmentAdherence Boolean?
  wantsStaffFollowUp Boolean        @default(false)
  difficultMoments   String[]
  copingToolsUsed    String[]
  notes              String?
  gratitude          String?
  createdAt          DateTime       @default(now())

  @@unique([consumerId, checkInDate])
}

model CheckInReview {
  id                  String       @id @default(cuid())
  checkInId           String       @unique
  checkIn             DailyCheckIn @relation(fields: [checkInId], references: [id])
  tenantId            String
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  consumerId          String
  consumer            Consumer     @relation(fields: [consumerId], references: [id])
  reviewerUserId      String?
  reviewer            User?        @relation(fields: [reviewerUserId], references: [id])
  status              String       @default("pending")
  followUpStatus      String       @default("not_needed")
  reviewNote          String?
  reviewedAt          DateTime?
  outreachCompletedAt DateTime?
  riskFlagged         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([consumerId, updatedAt])
  @@index([organizationId, status])
}

model JournalEntry {
  id                 String   @id @default(cuid())
  organizationId     String
  consumerId         String
  consumer           Consumer @relation(fields: [consumerId], references: [id])
  title              String
  content            String
  moodScore          Int?
  theme              String?
  sharedWithCareTeam Boolean  @default(false)
  aiSummary          String?
  createdAt          DateTime @default(now())
}

model ClinicalNote {
  id                 String       @id @default(cuid())
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  consumerId         String
  consumer           Consumer     @relation(fields: [consumerId], references: [id])
  authorUserId       String
  author             User         @relation(fields: [authorUserId], references: [id])
  noteType           String       @default("progress")
  title              String?
  body               String
  flaggedForFollowUp Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([consumerId, createdAt])
  @@index([organizationId, createdAt])
}

model Goal {
  id             String    @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer  @relation(fields: [consumerId], references: [id])
  title          String
  description    String?
  category       String?
  targetLabel    String?
  status         String
  targetDate     DateTime?
}

model Routine {
  id             String              @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer            @relation(fields: [consumerId], references: [id])
  title          String
  description    String?
  category       String?
  frequency      String
  targetPerWeek  Int?
  isActive       Boolean             @default(true)
  completions    RoutineCompletion[]
}

model RoutineCompletion {
  id             String   @id @default(cuid())
  organizationId String
  routineId      String
  routine        Routine  @relation(fields: [routineId], references: [id])
  completionDate DateTime
  createdAt      DateTime @default(now())

  @@unique([routineId, completionDate])
}

model RecoveryPlan {
  id               String   @id @default(cuid())
  organizationId   String
  consumerId       String   @unique
  consumer         Consumer @relation(fields: [consumerId], references: [id])
  summary          String
  focusAreas       Json
  copingStrategies Json
  reminders        Json
  supportContacts  Json
  safetyPlan       Json
  milestones       Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ConsumerCondition {
  id                   String          @id @default(cuid())
  organizationId       String
  consumerId           String
  consumer             Consumer        @relation(fields: [consumerId], references: [id])
  name                 String
  status               ConditionStatus
  accommodation        String?
  symptomScore         Int?
  traumaTriggerProfile Json?
}

model TreatmentPlan {
  id             String    @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer  @relation(fields: [consumerId], references: [id])
  clinicianId    String?
  goals          Json
  interventions  Json
  reviewDate     DateTime?
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  consumerId     String
  consumer       Consumer          @relation(fields: [consumerId], references: [id])
  type           String
  status         AppointmentStatus
  startsAt       DateTime
  endsAt         DateTime
  note           SessionNote?
}

model SessionNote {
  id             String      @id @default(cuid())
  organizationId String
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  subjective     String
  objective      String
  assessment     String
  plan           String
}

model GroupSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  topic          String
  startsAt       DateTime
  endsAt         DateTime
}

model MedicationRecord {
  id             String   @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer @relation(fields: [consumerId], references: [id])
  medicationName String
  dosage         String?
  schedule       String?
}

model Payer {
  id       String          @id @default(cuid())
  tenantId String
  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  name     String
  plans    InsurancePlan[]
}

model InsurancePlan {
  id           String        @id @default(cuid())
  payerId      String
  payer        Payer         @relation(fields: [payerId], references: [id])
  name         String
  coverages    Coverage[]
  feeSchedules FeeSchedule[]
}

model Coverage {
  id               String            @id @default(cuid())
  organizationId   String
  consumerId       String
  consumer         Consumer          @relation(fields: [consumerId], references: [id])
  planId           String
  plan             InsurancePlan     @relation(fields: [planId], references: [id])
  memberId         String
  groupNumber      String?
  isActive         Boolean           @default(true)
  authorizations   Authorization[]
  billingWorkItems BillingWorkItem[]
}

model Authorization {
  id              String   @id @default(cuid())
  organizationId  String
  coverageId      String
  coverage        Coverage @relation(fields: [coverageId], references: [id])
  serviceType     String
  authorizedUnits Int
  startDate       DateTime
  endDate         DateTime
}

model Encounter {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  consumerId       String
  consumer         Consumer          @relation(fields: [consumerId], references: [id])
  appointmentId    String?
  serviceCode      String
  status           String
  charges          Charge[]
  claims           Claim[]
  billingWorkItems BillingWorkItem[]
}

model Charge {
  id             String    @id @default(cuid())
  organizationId String
  encounterId    String
  encounter      Encounter @relation(fields: [encounterId], references: [id])
  cptCode        String
  amountCents    Int
}

model FeeSchedule {
  id          String        @id @default(cuid())
  planId      String
  plan        InsurancePlan @relation(fields: [planId], references: [id])
  serviceCode String
  rateCents   Int
}

model Claim {
  id               String            @id @default(cuid())
  organizationId   String
  encounterId      String
  encounter        Encounter         @relation(fields: [encounterId], references: [id])
  status           ClaimStatus
  billedCents      Int
  paidCents        Int?
  denialReason     String?
  denials          Denial[]
  remittance       Remittance?
  billingWorkItems BillingWorkItem[]
}

model BillingWorkItem {
  id              String                    @id @default(cuid())
  tenantId        String
  tenant          Tenant                    @relation(fields: [tenantId], references: [id])
  organizationId  String
  organization    Organization              @relation(fields: [organizationId], references: [id])
  consumerId      String
  consumer        Consumer                  @relation(fields: [consumerId], references: [id])
  encounterId     String?
  encounter       Encounter?                @relation(fields: [encounterId], references: [id])
  claimId         String?
  claim           Claim?                    @relation(fields: [claimId], references: [id])
  coverageId      String?
  coverage        Coverage?                 @relation(fields: [coverageId], references: [id])
  createdByUserId String
  createdBy       User                      @relation("BillingWorkItemCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUserId String?
  updatedBy       User?                     @relation("BillingWorkItemUpdatedBy", fields: [updatedByUserId], references: [id])
  title           String
  status          BillingWorkItemStatus     @default(draft)
  priority        String                    @default("normal")
  payerName       String?
  issueSummary    String?
  nextAction      String?
  amountCents     Int?
  serviceDate     DateTime?
  submittedAt     DateTime?
  notes           BillingNote[]
  activities      BillingWorkItemActivity[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([organizationId, status, updatedAt])
  @@index([consumerId, updatedAt])
}

model BillingNote {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  consumerId     String
  consumer       Consumer         @relation(fields: [consumerId], references: [id])
  workItemId     String?
  workItem       BillingWorkItem? @relation(fields: [workItemId], references: [id])
  authorUserId   String
  author         User             @relation("BillingNoteAuthor", fields: [authorUserId], references: [id])
  noteType       String           @default("billing_note")
  body           String
  createdAt      DateTime         @default(now())

  @@index([consumerId, createdAt])
  @@index([workItemId, createdAt])
}

model BillingWorkItemActivity {
  id             String                 @id @default(cuid())
  organizationId String
  workItemId     String
  workItem       BillingWorkItem        @relation(fields: [workItemId], references: [id])
  actorUserId    String?
  actor          User?                  @relation("BillingWorkItemActivityActor", fields: [actorUserId], references: [id])
  action         String
  fromStatus     BillingWorkItemStatus?
  toStatus       BillingWorkItemStatus?
  detail         String?
  createdAt      DateTime               @default(now())

  @@index([workItemId, createdAt])
}

model Remittance {
  id             String   @id @default(cuid())
  organizationId String
  claimId        String   @unique
  claim          Claim    @relation(fields: [claimId], references: [id])
  amountCents    Int
  receivedAt     DateTime
}

model Denial {
  id             String  @id @default(cuid())
  organizationId String
  claimId        String
  claim          Claim   @relation(fields: [claimId], references: [id])
  code           String
  reason         String
  resolved       Boolean @default(false)
}

model PatientLedgerEntry {
  id             String   @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer @relation(fields: [consumerId], references: [id])
  type           String
  amountCents    Int
  occurredAt     DateTime @default(now())
}

model Invoice {
  id             String    @id @default(cuid())
  organizationId String
  consumerId     String
  consumer       Consumer  @relation(fields: [consumerId], references: [id])
  status         String
  totalCents     Int
  dueDate        DateTime?
}

model PromptRegistry {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  actionType     AiActionType
  version        String
  promptTemplate String
  guardrails     Json
  active         Boolean      @default(true)
}

model AiRun {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  actionType    AiActionType
  inputSummary  String
  outputSummary String?
  blocked       Boolean      @default(false)
  createdAt     DateTime     @default(now())
}

model AuditLog {
  id                     String   @id @default(cuid())
  tenantId               String
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id])
  organizationId         String?
  sessionId              String?
  supportAccessSessionId String?
  supportMode            Boolean  @default(false)
  action                 String
  entityType             String
  entityId               String?
  metadata               Json?
  createdAt              DateTime @default(now())

  @@index([organizationId])
  @@index([sessionId])
  @@index([supportAccessSessionId])
}
