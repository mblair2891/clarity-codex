# Shared
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info
JWT_ISSUER=clarity-bridge-health
JWT_AUDIENCE=clarity-platform
JWT_SECRET=replace-me-with-a-32-character-secret

# Database & stateful services
DATABASE_URL=postgresql://clarity:clarity@localhost:5432/clarity_bridge?schema=public
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=clarity-bridge-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
AI_PROVIDER=demo
OPENAI_API_KEY=

# Web
NEXT_PUBLIC_APP_NAME=Clarity Bridge Health
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# API
HOST=0.0.0.0
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

