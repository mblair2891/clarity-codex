{
  "name": "clarity-bridge-health",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w @clarity/api",
    "dev:web": "npm run dev -w @clarity/web",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "node scripts/seed-beta.mjs",
    "db:cleanup": "node scripts/cleanup-beta-data.mjs",
    "db:verify-clean": "node scripts/verify-beta-clean.mjs",
    "db:bootstrap-admin": "node scripts/bootstrap-admin.mjs",
    "db:backfill:access-phase1": "node scripts/backfill-access-phase1.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "npm-run-all": "^4.1.5",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2"
  }
}
