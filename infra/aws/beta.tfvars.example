aws_region        = "us-east-1"
environment       = "beta"
project_name      = "clarity"
domain_name       = "claritybridgehealth.com"
route53_zone_name = "claritybridgehealth.com"
image_tag         = "latest"

web_subdomain      = "beta-app"
clinical_subdomain = "beta-clinical"
api_subdomain      = "beta-api"

next_public_app_name = "Clarity Bridge Health"
jwt_issuer           = "clarity-bridge-health"
jwt_audience         = "clarity-platform"
# beta_login_code    = "replace-with-a-shared-beta-access-code"
ai_provider          = "demo"

enable_redis = false
redis_url    = ""
